, 			{
				"box" : 				{
					"code" : "/**\r\n * syncSender.js\r\n * \r\n * This script manages a named dictionary and notifies other devices\r\n * when the data has changed.\r\n */\r\n\r\nvar myDict = new Dict(\"shared_data\");\r\nlet currentSequence = 1\r\n// Example function to update a value\r\nfunction set_value(key, value) {\r\n    myDict.set(key, value);\r\n    notify(); \r\n}\r\n\r\n// Function to replace the entire dictionary content\r\nfunction set_dict(dictName) {\r\n    myDict.replace(dictName);\r\n    notify();\r\n}\r\n\r\n// Global notification\r\nfunction notify() {\r\n    messnamed(\"sync_dictionary_changed\", \"bang\");\r\n    post(\"Sync: Dictionary updated and notification sent.\\n\");\r\n}\r\n\r\nfunction setSequence(val){\r\n\tcurrentSequence = val\r\n}\r\n\r\nfunction setTime(val){\r\n\tmyDict.set(\"sequences::\" + currentSequence + \"::time\" , val )\r\n}\r\n\r\nfunction setTime(val){\r\n\tmyDict.set(\"sequences::\" + currentSequence + \"::direction\" , val )\r\n}\r\n\r\n\r\nfunction bang() {\r\n    post(\"Current data: \" + myDict.stringify() + \"\\n\");\r\n}\r\n\r\nfunction sendNotify(){\r\n\tnotify()\r\n}\r\n",
					"filename" : "none",
					"fontface" : 0,
					"fontname" : "<Monospaced>",
					"fontsize" : 12.0,
					"id" : "obj-2",
