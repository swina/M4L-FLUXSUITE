					"hint" : "Shift Time",
					"id" : "obj-48",
					"items" : [ "OFF", ",", "2/1", ",", "1/1", ",", "1/2", ",", "1/3", ",", "1/4", ",", "1/6", ",", "1/8", ",", "1/12", ",", "1/16", ",", "1/32", ",", "1/64", ",", "1/128" ],
					"maxclass" : "umenu",
