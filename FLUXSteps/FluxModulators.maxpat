, 			{
				"box" : 				{
					"code" : "let timingStr = \"1/1\"\r\nlet bpm = 120\r\n\r\nfunction setBPM(val){\r\n\tbpm = parseFloat(val)\r\n\ttimingToMs()\r\n}\r\nfunction setTiming(val){\r\n\tif ( val == 'OFF' ) {\r\n\t\toutlet(0,\"reset\",0)\r\n\t\t\r\n\t}\r\n\t\r\n\ttimingStr = val\r\n\ttimingToMs()\r\n}\r\nfunction timingToMs() {\r\n    if (!timingStr || !bpm) return 0;\r\n    \r\n    var parts = timingStr.split('/');\r\n    if (parts.length !== 2) return 0;\r\n    \r\n    var numerator = parseFloat(parts[0]);\r\n    var denominator = parseFloat(parts[1]);\r\n    \r\n    if (isNaN(numerator) || isNaN(denominator) || denominator === 0) return 0;\r\n    \r\n    var quarterNoteMs = 60000 / bpm;\r\n    var wholeNoteMs = quarterNoteMs * 4;\r\n    var result = wholeNoteMs * (numerator / denominator);\r\n    outlet(0,\"ms\",result)\r\n\tif ( result != 0 ){\r\n\t\toutlet(0,\"hz\",(1000 / result).toFixed(2));\r\n\t} \r\n    return result;\r\n}",
					"filename" : "none",
					"fontface" : 0,
					"fontname" : "<Monospaced>",
					"fontsize" : 12.0,
					"id" : "obj-47",
					"maxclass" : "v8.codebox",
					"numinlets" : 1,
					"numoutlets" : 1,
					"outlettype" : [ "" ],
					"patching_rect" : [ 502.0, 287.0, 354.0, 292.0 ],
					"saved_object_attributes" : 					{
						"parameter_enable" : 0
					}
,
					"varname" : "v8_AA"
				}

			}
